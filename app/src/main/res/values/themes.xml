<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Simple theme for compatibility -->
    <style name="Theme.IntimoCoffeeApp" parent="@android:style/Theme.Material.Light.NoActionBar">
        <!-- Primary colors -->
        <item name="android:colorPrimary">@color/black_primary</item>
        <item name="android:colorAccent">@color/gray_medium</item>
        <item name="android:colorBackground">@color/white_off</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/black_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/black_primary</item>
    </style>
    
    <!-- Waiter app theme with blue accent for service items -->
    <style name="Theme.IntimoCoffeeWaiter" parent="@android:style/Theme.Material.Light.NoActionBar">
        <!-- Primary colors -->
        <item name="android:colorPrimary">#1976D2</item>
        <item name="android:colorAccent">#2196F3</item>
        <item name="android:colorBackground">@color/white_off</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">#1976D2</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Navigation bar -->
        <item name="android:navigationBarColor">#1976D2</item>
    </style>
</resources>
